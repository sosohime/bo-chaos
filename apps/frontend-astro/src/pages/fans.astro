---
import '@mono/config-tailwind/global.css';
import Layout from '../layouts/Layout.astro';
import image2 from '../assets/image2-crab.png';

const crabNotes = ['中华绒螯蟹', '家养大闸蟹', '已退休'];
---

<Layout title="姚金龟 - BoFans" description="BoFans 成员姚金龟的轻量简介。">
  <main
    class="min-h-screen bg-[#f7fbf8] px-4 py-6 text-stone-950 [overflow-wrap:anywhere] sm:px-6 sm:py-10"
  >
    <section
      class="mx-auto grid w-full max-w-5xl min-w-0 grid-cols-1 gap-6 overflow-hidden border border-stone-900/10 bg-white shadow-[0_18px_60px_rgba(32,46,37,0.08)] md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]"
    >
      <div
        class="flex min-h-[28rem] min-w-0 flex-col justify-between gap-8 px-5 py-6 sm:px-7 sm:py-8"
      >
        <p
          class="font-mono text-xs uppercase tracking-[0.18em] text-emerald-800"
        >
          BOFANS PROFILE
        </p>

        <div>
          <h1 class="text-4xl font-semibold leading-tight sm:text-5xl">
            姚金龟
          </h1>
          <p class="mt-3 text-base leading-7 text-stone-700">
            已退休的 BoFans 成员。页面不铺太满，留一点河风和蟹塘气息。
          </p>
        </div>

        <div class="flex flex-wrap gap-2">
          {
            crabNotes.map((note) => (
              <span class="border border-emerald-900/15 bg-emerald-50 px-3 py-1.5 text-sm text-emerald-950">
                {note}
              </span>
            ))
          }
        </div>

        <div
          class="grid min-w-0 gap-3 text-sm leading-6 text-stone-700 sm:grid-cols-2"
        >
          <article class="min-w-0 border border-stone-900/10 bg-[#fffaf0] p-4">
            <h2 class="mb-2 font-medium text-stone-950">公开状态</h2>
            <p>BoFans · 已退休。适合轻轻放在列表里，点进来有个记号。</p>
          </article>

          <article class="min-w-0 border border-stone-900/10 bg-[#f0fbf8] p-4">
            <h2 class="mb-2 font-medium text-stone-950">家传元素</h2>
            <p>家里养大闸蟹，所以主视觉交给中华绒螯蟹出场。</p>
          </article>
        </div>
      </div>

      <div class="flex min-w-0 flex-col justify-between bg-[#e9f7f2] p-3">
        <figure class="overflow-hidden border border-emerald-950/10 bg-white">
          <img
            src={image2.src}
            alt="两只中华绒螯蟹停在竹筛上的蟹塘插画"
            class="aspect-[16/9] h-full w-full object-cover"
          />
        </figure>

        <div
          class="mt-3 grid grid-cols-[auto_minmax(0,1fr)] gap-3 border border-emerald-950/10 bg-white p-4 text-sm leading-6 text-stone-700"
        >
          <span class="font-mono text-emerald-800">01</span>
          <p>绒螯、竹篓、浅水蟹塘，给这个轻量页面加一点独有的辨识度。</p>
        </div>
      </div>
    </section>

    <section class="mx-auto mt-4 w-full max-w-5xl">
      <a
        href="../"
        class="inline-flex items-center gap-2 text-sm text-stone-600 underline-offset-4 hover:text-stone-950 hover:underline"
      >
        <span class="font-mono text-emerald-800">←</span>
        返回退休页
      </a>
    </section>
  </main>
</Layout>
