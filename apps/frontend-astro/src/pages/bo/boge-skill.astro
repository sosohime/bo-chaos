---
import '@mono/config-tailwind/global.css';
import Layout from '../../layouts/Layout.astro';
import { sitePath } from '../../lib/site-paths';

const githubUrl =
  'https://github.com/sosohime/bo-chaos/tree/main/packages/agent-skills';
const rawBaseUrl =
  'https://raw.githubusercontent.com/sosohime/bo-chaos/main/packages/agent-skills';
const macInstaller = `${rawBaseUrl}/install-boshuo.sh`;
const windowsInstaller = `${rawBaseUrl}/install-boshuo.ps1`;
const darkCodeBlockClass =
  'max-w-full overflow-x-auto whitespace-pre-wrap break-all bg-neutral-950 p-3 text-xs leading-5 text-white sm:text-sm sm:leading-6';
const lightCodeBlockClass =
  'max-w-full overflow-x-auto whitespace-pre-wrap break-all bg-neutral-50 p-3 text-xs leading-5 text-neutral-800 sm:text-sm sm:leading-6';

const commands = [
  {
    id: 'both-mac',
    title: 'Codex + Claude Code · macOS / Linux',
    note: '默认同时写入 ~/.codex/skills 和 ~/.claude/skills',
    command: `bash -lc "$(curl -fsSL ${macInstaller})"`,
    tone: 'dark',
  },
  {
    id: 'project-mac',
    title: '当前项目 .agents · macOS / Linux',
    note: '在仓库里写入 .agents/skills/boshuo',
    command: `AGENT_TARGET=agents bash -lc "$(curl -fsSL ${macInstaller})"`,
    tone: 'light',
  },
  {
    id: 'both-win',
    title: 'Codex + Claude Code · Windows PowerShell',
    note: '默认同时写入 .codex\\skills 和 .claude\\skills',
    command: `irm ${windowsInstaller} | iex`,
    tone: 'dark',
  },
];

const removeCommands = [
  {
    id: 'remove-user-mac',
    title: '删除用户级安装 · macOS / Linux',
    command:
      'rm -rf ~/.codex/skills/boshuo ~/.claude/skills/boshuo ~/.codex/skills/boge-oral-persona ~/.claude/skills/boge-oral-persona',
  },
  {
    id: 'remove-project-mac',
    title: '删除项目 .agents 安装 · macOS / Linux',
    command: 'rm -rf .agents/skills/boshuo .agents/skills/boge-oral-persona',
  },
  {
    id: 'remove-user-win',
    title: '删除用户级安装 · Windows PowerShell',
    command:
      'Remove-Item -Recurse -Force "$HOME\\.codex\\skills\\boshuo","$HOME\\.claude\\skills\\boshuo","$HOME\\.codex\\skills\\boge-oral-persona","$HOME\\.claude\\skills\\boge-oral-persona" -ErrorAction SilentlyContinue',
  },
];

const removePrompt =
  '帮我删除博说 Skill，Codex、Claude Code 和当前项目 .agents 里的都清掉。';

const agentRequests = [
  {
    id: 'agent-both',
    title: '装到自己的 agent',
    prompt: `帮我安装博说 Skill，Codex 和 Claude Code 都装好。安装源是 ${githubUrl}`,
  },
  {
    id: 'agent-project',
    title: '装到当前项目',
    prompt: `帮我把博说 Skill 装进当前仓库的 .agents，让这个项目里的 agent 都能用。安装源是 ${githubUrl}`,
  },
];
---

<Layout
  title="安装博说 Skill - 博Fans"
  description="安装博说 Skill 到 Codex、Claude Code 或项目 .agents 目录，并了解如何启用、关闭和删除。"
>
  <main
    class="min-h-screen w-full overflow-x-hidden bg-[#f6f8ff] px-3 py-3 text-neutral-950 sm:px-4 sm:py-4"
  >
    <section
      class="mx-auto flex min-h-[calc(100vh-1.5rem)] w-full min-w-0 max-w-6xl flex-col overflow-hidden border border-neutral-950/10 bg-white shadow-[0_18px_70px_rgba(15,23,42,0.06)]"
    >
      <div
        class="relative flex min-w-0 flex-col justify-between overflow-hidden border-b border-neutral-950/10 bg-[#f0f7ff] p-4 sm:p-6"
      >
        <div
          class="pointer-events-none absolute inset-0 opacity-80"
          style="background-image: linear-gradient(rgba(0, 82, 217, 0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 82, 217, 0.08) 1px, transparent 1px); background-size: 30px 30px;"
          aria-hidden="true"
        >
        </div>

        <div class="relative flex items-center justify-between gap-3">
          <a
            class="font-mono text-xs text-[#0052D9] underline-offset-4 hover:underline"
            href={sitePath('/bo')}
          >
            ← back to bo
          </a>
          <span class="min-w-0 truncate font-mono text-[11px] text-neutral-500">
            boshuo
          </span>
        </div>

        <div
          class="relative grid gap-5 py-6 md:grid-cols-[auto_minmax(0,1fr)] md:items-end"
        >
          <div class="flex min-w-0 items-end gap-5">
            <img
              class="h-auto w-24 shrink-0 object-contain drop-shadow-[0_18px_28px_rgba(15,23,42,0.16)] sm:w-32"
              src={sitePath('/codex-pets/expertbo-preview.png')}
              width="252"
              height="262"
              alt="ExpertBo preview"
            />
            <div
              class="min-w-0 border border-neutral-950/10 bg-white/86 p-3 shadow-[0_18px_38px_rgba(15,23,42,0.08)] backdrop-blur"
            >
              <p class="text-sm leading-6 text-neutral-500">
                你：今天不想上班。
              </p>
              <p
                class="mt-2 text-lg font-semibold leading-snug text-neutral-950"
              >
                博哥：又是一个你妈嗨的一天我草泥马。
              </p>
              <p class="mt-2 text-sm leading-6 text-neutral-700">
                人这辈子，对吧
              </p>
            </div>
          </div>

          <div
            class="grid gap-2 font-mono text-xs text-neutral-700 sm:grid-cols-2"
          >
            <div class="border border-neutral-950/10 bg-white/82 px-3 py-2">
              必须必须了。💪
            </div>
            <div class="border border-neutral-950/10 bg-white/82 px-3 py-2">
              真垃圾，好像前端做的。
            </div>
            <div class="border border-neutral-950/10 bg-white/82 px-3 py-2">
              这b玩意有点闹心。
            </div>
            <div class="border border-neutral-950/10 bg-white/82 px-3 py-2">
              都是说法，你懂我意思吧。
            </div>
          </div>
        </div>
      </div>

      <div class="flex min-w-0 flex-col">
        <header
          class="min-w-0 border-b border-neutral-950/10 px-4 py-5 sm:px-6"
        >
          <p
            class="font-mono text-[11px] uppercase tracking-[0.16em] text-[#0052D9]"
          >
            Agent skill install guide
          </p>
          <h1
            class="mt-3 text-2xl font-semibold leading-tight text-neutral-950 sm:text-3xl"
          >
            安装博说 Skill
          </h1>
          <p
            class="mt-3 max-w-2xl text-sm leading-6 text-neutral-600 sm:text-base"
          >
            装完以后，你跟 agent 说“让博哥说”“来点博哥味”“上点强度”，
            它就按这套口气回你；想关掉就说“正常说话”。
          </p>
        </header>

        <div class="min-w-0 flex-1 px-4 py-5 sm:px-6">
          <div class="flex min-w-0 items-center justify-between gap-3">
            <h2
              id="install-command-title"
              class="flex items-center gap-3 text-base font-semibold text-neutral-950"
            >
              <span class="font-mono text-xs text-[#0052D9]">▹</span>
              直接跟 agent 说
            </h2>
            <a
              class="font-mono text-xs text-[#0052D9] underline-offset-4 hover:underline"
              href={githubUrl}
              target="_blank"
              rel="noreferrer"
            >
              GitHub
            </a>
          </div>

          <div class="mt-4 grid min-w-0 gap-4">
            {
              agentRequests.map((item) => (
                <section
                  class="min-w-0 border border-neutral-950/10"
                  aria-labelledby={`agent-${item.id}`}
                >
                  <div class="flex min-w-0 items-center justify-between gap-3 border-b border-neutral-950/10 bg-neutral-50 px-3 py-3">
                    <h3
                      id={`agent-${item.id}`}
                      class="text-base font-semibold text-neutral-950"
                    >
                      {item.title}
                    </h3>
                    <button
                      class="shrink-0 border border-neutral-950/10 bg-white px-3 py-1.5 font-mono text-xs text-neutral-700 transition-colors hover:border-[#0052D9] hover:text-[#0052D9]"
                      type="button"
                      data-copy-command={item.prompt}
                    >
                      复制
                    </button>
                  </div>
                  <pre class={darkCodeBlockClass}>
                    <code>{item.prompt}</code>
                  </pre>
                </section>
              ))
            }
          </div>

          <section
            class="mt-6 border-t border-neutral-950/10 pt-5"
            aria-labelledby="manual-install-title"
          >
            <h2
              id="manual-install-title"
              class="flex items-center gap-3 text-base font-semibold text-neutral-950"
            >
              <span class="font-mono text-xs text-[#0052D9]">▹</span>
              手动备用
            </h2>
            <p class="mt-2 text-sm leading-6 text-neutral-600">
              agent 装不了的时候再用。默认命令会同时装 Codex 和 Claude Code；
              `.agents` 命令用于项目共享。
            </p>
            <details class="mt-4 border border-neutral-950/10 bg-neutral-50">
              <summary
                class="cursor-pointer px-3 py-3 text-sm font-semibold text-neutral-950"
              >
                展开手动命令
              </summary>
              <div
                class="grid min-w-0 gap-4 border-t border-neutral-950/10 p-3"
              >
                {
                  commands.map((item) => (
                    <section
                      class="min-w-0 border border-neutral-950/10 bg-white"
                      aria-labelledby={`install-${item.id}`}
                    >
                      <div class="flex min-w-0 items-center justify-between gap-3 border-b border-neutral-950/10 bg-white px-3 py-3">
                        <div class="min-w-0">
                          <h3
                            id={`install-${item.id}`}
                            class="text-base font-semibold text-neutral-950"
                          >
                            {item.title}
                          </h3>
                          <p class="mt-1 text-xs leading-5 text-neutral-500">
                            {item.note}
                          </p>
                        </div>
                        <button
                          class="shrink-0 border border-neutral-950/10 bg-white px-3 py-1.5 font-mono text-xs text-neutral-700 transition-colors hover:border-[#0052D9] hover:text-[#0052D9]"
                          type="button"
                          data-copy-command={item.command}
                        >
                          复制
                        </button>
                      </div>
                      <pre
                        class={
                          item.tone === 'dark'
                            ? darkCodeBlockClass
                            : lightCodeBlockClass
                        }
                      >
                        <code>{item.command}</code>
                      </pre>
                    </section>
                  ))
                }
              </div>
            </details>
          </section>

          <section
            class="mt-6 border-t border-neutral-950/10 pt-5"
            aria-labelledby="use-title"
          >
            <h2
              id="use-title"
              class="flex items-center gap-3 text-base font-semibold text-neutral-950"
            >
              <span class="font-mono text-xs text-[#0052D9]">▹</span>
              启用和关闭
            </h2>
            <div class="mt-4 grid gap-3 sm:grid-cols-2">
              <div class="border border-neutral-950/10 bg-neutral-50 p-3">
                <h3 class="font-mono text-xs text-[#0052D9]">启用</h3>
                <ul class="mt-2 space-y-1 text-sm leading-6 text-neutral-700">
                  <li>让博哥说</li>
                  <li>来点博哥味</li>
                  <li>上点强度</li>
                  <li>博哥锐评一下</li>
                </ul>
              </div>
              <div class="border border-neutral-950/10 bg-neutral-50 p-3">
                <h3 class="font-mono text-xs text-[#0052D9]">关闭</h3>
                <ul class="mt-2 space-y-1 text-sm leading-6 text-neutral-700">
                  <li>让博哥别说了</li>
                  <li>正常说话</li>
                  <li>用正式语气</li>
                  <li>这句正常点</li>
                </ul>
              </div>
            </div>
          </section>

          <section
            class="mt-6 border-t border-neutral-950/10 pt-5"
            aria-labelledby="remove-title"
          >
            <h2
              id="remove-title"
              class="flex items-center gap-3 text-base font-semibold text-neutral-950"
            >
              <span class="font-mono text-xs text-[#0052D9]">▹</span>
              删除
            </h2>
            <div class="mt-4 min-w-0 border border-neutral-950/10">
              <div
                class="flex min-w-0 items-center justify-between gap-3 border-b border-neutral-950/10 bg-neutral-50 px-3 py-3"
              >
                <h3 class="text-sm font-semibold text-neutral-950">
                  跟 agent 说
                </h3>
                <button
                  class="shrink-0 border border-neutral-950/10 bg-white px-3 py-1.5 font-mono text-xs text-neutral-700 transition-colors hover:border-[#0052D9] hover:text-[#0052D9]"
                  type="button"
                  data-copy-command={removePrompt}
                >
                  复制
                </button>
              </div>
              <pre class={darkCodeBlockClass}><code>{removePrompt}</code></pre>
            </div>
            <details class="mt-4 border border-neutral-950/10 bg-neutral-50">
              <summary
                class="cursor-pointer px-3 py-3 text-sm font-semibold text-neutral-950"
              >
                展开删除命令
              </summary>
              <div
                class="grid min-w-0 gap-4 border-t border-neutral-950/10 p-3"
              >
                {
                  removeCommands.map((item) => (
                    <section class="min-w-0 border border-neutral-950/10 bg-white">
                      <div class="flex min-w-0 items-center justify-between gap-3 border-b border-neutral-950/10 bg-white px-3 py-3">
                        <h3 class="text-sm font-semibold text-neutral-950">
                          {item.title}
                        </h3>
                        <button
                          class="shrink-0 border border-neutral-950/10 bg-white px-3 py-1.5 font-mono text-xs text-neutral-700 transition-colors hover:border-[#0052D9] hover:text-[#0052D9]"
                          type="button"
                          data-copy-command={item.command}
                        >
                          复制
                        </button>
                      </div>
                      <pre class={lightCodeBlockClass}>
                        <code>{item.command}</code>
                      </pre>
                    </section>
                  ))
                }
              </div>
            </details>
          </section>
        </div>
      </div>
    </section>
  </main>

  <script>
    const copyButtons = document.querySelectorAll('[data-copy-command]');

    copyButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        const command = button.getAttribute('data-copy-command');
        const initialText = button.textContent;
        if (!command) return;

        try {
          await navigator.clipboard.writeText(command);
          button.textContent = '已复制';
        } catch {
          button.textContent = '复制失败';
        }

        window.setTimeout(() => {
          button.textContent = initialText;
        }, 1400);
      });
    });
  </script>
</Layout>
