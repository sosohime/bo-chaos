---
import '@mono/config-tailwind/global.css';
import Layout from '../../layouts/Layout.astro';
import { sitePath } from '../../lib/site-paths';

const githubUrl =
  'https://github.com/sosohime/bo-chaos/tree/main/packages/codex-pets';

const pets = [
  {
    id: 'expertbo',
    displayName: 'ExpertBo',
    label: '专家款',
    description: '稳定专家 Bo，适合日常 Codex 桌宠陪伴。',
    previewImageSrc: sitePath('/codex-pets/expertbo-preview.png'),
    imageWidth: 252,
    imageHeight: 262,
    macInstallCommand:
      'bash -lc "$(curl -fsSL https://raw.githubusercontent.com/sosohime/bo-chaos/main/packages/codex-pets/install-expertbo.sh)"',
    windowsInstallCommand:
      'powershell -NoProfile -ExecutionPolicy Bypass -Command "irm https://raw.githubusercontent.com/sosohime/bo-chaos/main/packages/codex-pets/install-expertbo.ps1 | iex"',
  },
  {
    id: 'shadowbo',
    displayName: '影流Bo',
    label: '影流整活款',
    description: '三个 Bo 动作完全一致，只做位置错开。',
    previewImageSrc: sitePath('/codex-pets/shadowbo-preview.png'),
    imageWidth: 192,
    imageHeight: 208,
    macInstallCommand:
      'bash -lc "$(curl -fsSL https://raw.githubusercontent.com/sosohime/bo-chaos/main/packages/codex-pets/install-shadowbo.sh)"',
    windowsInstallCommand:
      'powershell -NoProfile -ExecutionPolicy Bypass -Command "irm https://raw.githubusercontent.com/sosohime/bo-chaos/main/packages/codex-pets/install-shadowbo.ps1 | iex"',
  },
];
---

<Layout
  title="安装 Codex 博哥小宠物 - 博Fans"
  description="安装 ExpertBo 和影流Bo Codex 桌面宠物的 GitHub 资源和本地安装引导。"
>
  <main
    class="min-h-screen w-full overflow-x-hidden bg-[#f6f8ff] px-3 py-3 text-neutral-950 sm:px-4 sm:py-4"
  >
    <section
      class="mx-auto flex min-h-[calc(100vh-1.5rem)] w-full min-w-0 max-w-6xl flex-col overflow-hidden border border-neutral-950/10 bg-white shadow-[0_18px_70px_rgba(15,23,42,0.06)]"
    >
      <div
        class="relative flex min-w-0 flex-col justify-between overflow-hidden border-b border-neutral-950/10 bg-[#edf6ff] p-4 sm:p-6"
      >
        <div
          class="pointer-events-none absolute inset-0 opacity-70"
          style="background-image: linear-gradient(rgba(0, 82, 217, 0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 82, 217, 0.08) 1px, transparent 1px); background-size: 30px 30px;"
          aria-hidden="true"
        >
        </div>
        <div class="relative flex items-center justify-between gap-3">
          <a
            class="font-mono text-xs text-[#0052D9] underline-offset-4 hover:underline"
            href={sitePath('/bo')}
          >
            ← back to bo
          </a>
          <span class="min-w-0 truncate font-mono text-[11px] text-neutral-500">
            custom:expertbo / custom:shadowbo
          </span>
        </div>

        <div
          class="relative grid grid-cols-2 items-end justify-items-center gap-3 py-5 sm:gap-5 sm:py-8 md:mx-auto md:w-full md:max-w-2xl"
        >
          {
            pets.map((pet) => (
              <div class="flex min-w-0 flex-col items-center">
                <img
                  class="h-auto w-auto max-h-[13rem] max-w-full object-contain drop-shadow-[0_18px_28px_rgba(15,23,42,0.16)]"
                  src={pet.previewImageSrc}
                  width={pet.imageWidth}
                  height={pet.imageHeight}
                  alt={`${pet.displayName} 桌宠示例图`}
                />
                <div class="mt-3 border border-neutral-950/10 bg-white/80 px-2 py-1 text-center font-mono text-[10px] text-neutral-500 backdrop-blur">
                  {pet.displayName}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div class="flex min-w-0 flex-col">
        <header
          class="min-w-0 border-b border-neutral-950/10 px-4 py-5 sm:px-6"
        >
          <p
            class="font-mono text-[11px] uppercase tracking-[0.16em] text-[#0052D9]"
          >
            Codex pets install guide
          </p>
          <h1
            class="mt-3 text-2xl font-semibold leading-tight text-neutral-950 sm:text-3xl"
          >
            安装 Codex 博哥小宠物
          </h1>
          <p
            class="mt-3 max-w-2xl text-sm leading-6 text-neutral-600 sm:text-base"
          >
            从 GitHub 拉取 ExpertBo 或影流Bo资源，写入本机 Codex
            自定义宠物目录，然后在设置里刷新并选择它。
          </p>
        </header>

        <div class="min-w-0 flex-1 px-4 py-5 sm:px-6">
          <div class="flex min-w-0 items-center justify-between gap-3">
            <h2
              id="install-command-title"
              class="flex items-center gap-3 text-base font-semibold text-neutral-950"
            >
              <span class="font-mono text-xs text-[#0052D9]">▹</span>
              一键安装
            </h2>
            <a
              class="font-mono text-xs text-[#0052D9] underline-offset-4 hover:underline"
              href={githubUrl}
              target="_blank"
              rel="noreferrer"
            >
              GitHub
            </a>
          </div>

          <div class="mt-4 grid min-w-0 gap-4">
            {
              pets.map((pet) => (
                <section
                  class="min-w-0 border border-neutral-950/10"
                  aria-labelledby={`install-${pet.id}`}
                >
                  <div class="flex min-w-0 flex-wrap items-start justify-between gap-3 border-b border-neutral-950/10 bg-neutral-50 px-3 py-3">
                    <div class="min-w-0">
                      <h3
                        id={`install-${pet.id}`}
                        class="text-base font-semibold text-neutral-950"
                      >
                        {pet.displayName}
                      </h3>
                      <p class="mt-1 text-xs leading-5 text-neutral-500">
                        {pet.label} · custom:{pet.id}
                      </p>
                      <p class="mt-1 text-sm leading-6 text-neutral-700">
                        {pet.description}
                      </p>
                    </div>
                  </div>

                  <div class="min-w-0 divide-y divide-neutral-950/10">
                    <div class="min-w-0">
                      <div class="flex min-w-0 items-center justify-between gap-3 px-3 py-2">
                        <span class="min-w-0 truncate font-mono text-[11px] text-neutral-500">
                          macOS / Linux / Git Bash
                        </span>
                        <button
                          class="shrink-0 border border-neutral-950/10 bg-white px-3 py-1.5 font-mono text-xs text-neutral-700 transition-colors hover:border-[#0052D9] hover:text-[#0052D9]"
                          type="button"
                          data-copy-command={pet.macInstallCommand}
                        >
                          复制
                        </button>
                      </div>
                      <pre class="max-w-full overflow-x-auto whitespace-pre-wrap break-all bg-neutral-950 p-3 text-xs leading-5 text-white sm:text-sm sm:leading-6">
                        <code>{pet.macInstallCommand}</code>
                      </pre>
                    </div>

                    <div class="min-w-0">
                      <div class="flex min-w-0 items-center justify-between gap-3 px-3 py-2">
                        <span class="min-w-0 truncate font-mono text-[11px] text-neutral-500">
                          Windows PowerShell
                        </span>
                        <button
                          class="shrink-0 border border-neutral-950/10 bg-white px-3 py-1.5 font-mono text-xs text-neutral-700 transition-colors hover:border-[#0052D9] hover:text-[#0052D9]"
                          type="button"
                          data-copy-command={pet.windowsInstallCommand}
                        >
                          复制
                        </button>
                      </div>
                      <pre class="max-w-full overflow-x-auto whitespace-pre-wrap break-all bg-neutral-50 p-3 text-xs leading-5 text-neutral-800 sm:text-sm sm:leading-6">
                        <code>{pet.windowsInstallCommand}</code>
                      </pre>
                    </div>
                  </div>
                </section>
              ))
            }
          </div>

          <section
            class="mt-6 border-t border-neutral-950/10 pt-5"
            aria-labelledby="activate-title"
          >
            <h2
              id="activate-title"
              class="flex items-center gap-3 text-base font-semibold text-neutral-950"
            >
              <span class="font-mono text-xs text-[#0052D9]">▹</span>
              Codex 里启用
            </h2>
            <div class="mt-4 grid min-w-0 gap-3 sm:grid-cols-2" role="list">
              <div
                class="grid grid-cols-[2rem_1fr] gap-3 text-sm leading-6 text-neutral-700"
                role="listitem"
              >
                <span
                  class="grid h-8 w-8 place-items-center rounded-full bg-[#0052D9] font-mono text-xs text-white"
                  >1</span
                >
                <span>打开 Settings -&gt; Appearance -&gt; Pets。</span>
              </div>
              <div
                class="grid grid-cols-[2rem_1fr] gap-3 text-sm leading-6 text-neutral-700"
                role="listitem"
              >
                <span
                  class="grid h-8 w-8 place-items-center rounded-full bg-[#0052D9] font-mono text-xs text-white"
                  >2</span
                >
                <span>点击 Refresh，等自定义宠物列表刷新。</span>
              </div>
              <div
                class="grid grid-cols-[2rem_1fr] gap-3 text-sm leading-6 text-neutral-700"
                role="listitem"
              >
                <span
                  class="grid h-8 w-8 place-items-center rounded-full bg-[#0052D9] font-mono text-xs text-white"
                  >3</span
                >
                <span>选择 ExpertBo 或影流Bo。</span>
              </div>
              <div
                class="grid grid-cols-[2rem_1fr] gap-3 text-sm leading-6 text-neutral-700"
                role="listitem"
              >
                <span
                  class="grid h-8 w-8 place-items-center rounded-full bg-[#0052D9] font-mono text-xs text-white"
                  >4</span
                >
                <span>如果画面没变，关闭再打开 Wake Pet。</span>
              </div>
            </div>
          </section>
        </div>
      </div>
    </section>
  </main>

  <script>
    const copyButtons = document.querySelectorAll('[data-copy-command]');

    copyButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        const command = button.getAttribute('data-copy-command');
        const initialText = button.textContent;
        if (!command) return;

        try {
          await navigator.clipboard.writeText(command);
          button.textContent = '已复制';
        } catch {
          button.textContent = '复制失败';
        }

        window.setTimeout(() => {
          button.textContent = initialText;
        }, 1400);
      });
    });
  </script>
</Layout>
