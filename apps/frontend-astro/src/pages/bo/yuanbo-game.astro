---
import '@mono/config-tailwind/global.css';
import Layout from '../../layouts/Layout.astro';
import { sitePath } from '../../lib/site-paths';

const expertBoSrc = import.meta.env.DEV
  ? '/codex-pets/expertbo-cutout.png'
  : sitePath('/codex-pets/expertbo-cutout.png');
const shadowBoSrc = import.meta.env.DEV
  ? '/codex-pets/shadowbo-cutout.png'
  : sitePath('/codex-pets/shadowbo-cutout.png');
const mapBoSrc = expertBoSrc;
const boHeadPatchSrc = import.meta.env.DEV
  ? '/codex-pets/expertbo-map-cutout.png'
  : sitePath('/codex-pets/expertbo-map-cutout.png');
const boWalkSrc = import.meta.env.DEV
  ? '/codex-pets/yuanbo-source2-walk-v1.png'
  : sitePath('/codex-pets/yuanbo-source2-walk-v1.png');
const boPortraitsSrc = import.meta.env.DEV
  ? '/codex-pets/yuanbo-source2-portraits-v1.png'
  : sitePath('/codex-pets/yuanbo-source2-portraits-v1.png');
---

<Layout
  title="袁博の极限售后"
  description="袁博の极限售后，一个 Phaser 驱动的像素经营网页 RPG。"
>
  <main class="yrpg-page">
    <section
      class="yrpg-stage"
      data-yuanbo-rpg
      data-bo-src={expertBoSrc}
      data-shadow-bo-src={shadowBoSrc}
      data-map-bo-src={mapBoSrc}
      data-bo-head-patch-src={boHeadPatchSrc}
      data-bo-walk-src={boWalkSrc}
      data-bo-portraits-src={boPortraitsSrc}
      aria-label="袁博の极限售后游戏画面"
    >
      <noscript>需要启用 JavaScript 才能游玩《袁博の极限售后》。</noscript>
    </section>
  </main>
</Layout>

<script>
  import { startYuanboGame } from '../../game/yuanbo/main';

  const root = document.querySelector('[data-yuanbo-rpg]');
  if (root instanceof HTMLElement) {
    const destroy = startYuanboGame(root);
    window.addEventListener('beforeunload', destroy, { once: true });
  }
</script>

<style>
  .yrpg-page {
    position: fixed;
    inset: 0;
    min-height: 100svh;
    overflow: hidden;
    background: linear-gradient(
        135deg,
        rgb(18 45 47 / 92%),
        rgb(12 24 31 / 96%)
      ),
      radial-gradient(
        circle at 25% 20%,
        rgb(248 215 106 / 22%),
        transparent 28%
      ),
      radial-gradient(circle at 78% 84%, rgb(48 160 120 / 16%), transparent 32%);
    color: #fff8dc;
  }

  .yrpg-stage {
    position: relative;
    display: grid;
    width: 100vw;
    height: 100svh;
    place-items: center;
    background:
      linear-gradient(90deg, rgb(255 248 220 / 4%) 1px, transparent 1px) 0 0 /
        24px 24px,
      linear-gradient(0deg, rgb(255 248 220 / 4%) 1px, transparent 1px) 0 0 /
        24px 24px;
  }

  .yrpg-stage :global(.yrpg-touch-bridge) {
    pointer-events: none;
    position: fixed;
    inset: 0;
    z-index: 8;
    display: none;
  }

  .yrpg-stage :global(.yrpg-touch-bridge[hidden]) {
    display: none !important;
  }

  .yrpg-stage :global(.yrpg-touch-bridge__stick),
  .yrpg-stage :global(.yrpg-touch-bridge__interact) {
    pointer-events: auto;
    position: absolute;
    border: 1px solid rgb(255 248 220 / 34%);
    background: rgb(13 31 35 / 74%);
    color: #fff8dc;
    font: inherit;
    font-weight: 950;
    line-height: 1;
    backdrop-filter: blur(8px);
    touch-action: none;
    user-select: none;
  }

  .yrpg-stage :global(.yrpg-touch-bridge__stick) {
    width: 7rem;
    height: 7rem;
    border-radius: 999px;
    background: rgb(13 31 35 / 48%);
    box-shadow: inset 0 0 0 1px rgb(255 248 220 / 18%);
  }

  .yrpg-stage :global(.yrpg-touch-bridge__knob) {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3rem;
    height: 3rem;
    border: 1px solid rgb(255 248 220 / 40%);
    border-radius: 999px;
    background: rgb(255 248 220 / 22%);
    transform: translate(-50%, -50%);
    box-shadow: 0 10px 28px rgb(0 0 0 / 22%);
  }

  .yrpg-stage :global(.yrpg-touch-bridge__interact) {
    display: grid;
    place-items: center;
    border-radius: 0;
    font-size: 1rem;
  }

  .yrpg-stage :global(canvas) {
    display: block;
    width: min(100vw, calc(100svh * 16 / 9)) !important;
    height: min(100svh, calc(100vw * 9 / 16)) !important;
    max-width: 100vw;
    max-height: 100svh;
    image-rendering: auto;
    box-shadow: 0 24px 80px rgb(0 0 0 / 34%);
  }

  @media (max-width: 720px) {
    .yrpg-stage :global(canvas) {
      width: 100vw !important;
      height: 100svh !important;
      max-height: 100svh;
      object-fit: contain;
    }

    .yrpg-stage :global(.yrpg-touch-bridge) {
      display: block;
    }

    .yrpg-stage :global(.yrpg-touch-bridge__stick) {
      left: 1.1rem;
      bottom: max(2.4rem, env(safe-area-inset-bottom));
    }

    .yrpg-stage :global(.yrpg-touch-bridge__interact) {
      right: 1.1rem;
      bottom: max(3.25rem, env(safe-area-inset-bottom));
      width: 4.7rem;
      height: 3.25rem;
      background: rgb(140 90 35 / 82%);
    }
  }
</style>
